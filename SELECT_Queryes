logical operators:- And, OR, NOT
-------------------------------
1. AND operation
SELECT * FROM employees WHERE department = 'IT' AND salary > 50000;
2. OR operation
SELECT * FROM employees WHERE department = 'IT' OR department = 'HR';
3. NOT operation
SELECT * FROM employees WHERE department != 'IT';

COMPARISON OPERATORS:-
---------------------
1. between the data to data
SELECT * FROM employees WHERE salary BETWEEN 30000 AND 60000;
2. between not in the data to data
SELECT * FROM employees WHERE salary NOT BETWEEN 30000 AND 60000;
3. specific data names to identify
SELECT * FROM employees WHERE department IN ('IT', 'HR', 'Sales');

pattern matching:-
-----------------
1. names starting with A.
SELECT * FROM employees WHERE emp_name LIKE 'A%';
2. names ending with N.
SELECT * FROM employees WHERE emp_name LIKE '%n';
3. names contain with ra.
SELECT * FROM employees WHERE emp_name LIKE '%ra%';
